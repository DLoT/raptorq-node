{
  "name": "@dlot/raptorq-node",
  "version": "1.0.0",
  "description": "Node bindings for raptorq",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/napi-rs/package-template.git"
  },
  "license": "MIT",
  "browser": "browser.js",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "raptorq-node.linux-arm64-gnu.node",
    "raptorq-node.linux-arm64-musl.node",
    "raptorq-node.linux-x64-gnu.node"
  ],
  "napi": {
    "binaryName": "raptorq-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --release --platform --target x86_64-unknown-linux-gnu --strip --no-js",
    "build:aarch64": "napi build --release --platform --target aarch64-unknown-linux-gnu --strip--no-js",
    "build:debug": "napi build --platform",
    "format:rs": "cargo fmt",
    "prepublishOnly": "napi prepublish -t npm",
    "preversion": "napi build --platform && git add .",
    "version": "napi version"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.5.1",
    "@oxc-node/core": "^0.0.35",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "yarn@4.13.0"
}
