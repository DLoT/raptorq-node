{
  "name": "@dlot/raptorq-node",
  "version": "1.0.0",
  "description": "Node bindings for raptorq",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/DLoT/raptorq-node.git"
  },
  "license": "MIT",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api",
    "raptorq"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "raptorq-node.linux-arm64-gnu.node",
    "raptorq-node.linux-x64-gnu.node"
  ],
  "napi": {
    "binaryName": "raptorq-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "build": "./build.sh"
  }
}
